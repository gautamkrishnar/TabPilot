# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL of the TabPilot API (without trailing slash).
# In development, the API runs on port 3000 and the web on 5173.
# In production (single container), both are served from port 3000 — leave empty
# so the web app defaults to the same origin.
VITE_API_URL=http://localhost:3000
