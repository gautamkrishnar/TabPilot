# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string.
# For local dev, start MongoDB with: podman compose -f compose.dev.yml up -d
MONGODB_URI=mongodb://localhost:27017/tabpilot

# For production (replica set / Atlas):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tabpilot?retryWrites=true&w=majority

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the API listens on. Containerfile exposes 3000.
PORT=3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the web frontend. Used for CORS allow-list.
# In production (single container) the API serves the SPA itself, so set this
# to the same origin as the API.
FRONTEND_URL=http://localhost:5173

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" in container deployments.
# In production, the API also serves the React SPA from apps/web/dist.
NODE_ENV=development

# ─── Jira Integration (optional) ──────────────────────────────────────────────
# When set, Jira issue titles are fetched and displayed in the URL queue.
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token_here
