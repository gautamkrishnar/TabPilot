# ─── TabPilot — root environment reference ────────────────────────────────────
#
# Copy the per-workspace files for local development:
#
#   cp apps/api/.env.example  apps/api/.env
#   cp apps/web/.env.example  apps/web/.env
#
# Then edit each file with your local values.
#
# ─── Quick reference ──────────────────────────────────────────────────────────
#
# apps/api/.env
# ┌─────────────────┬────────────────────────────────────────────────┬────────────────────────────────────┐
# │ Variable        │ Description                                    │ Default                            │
# ├─────────────────┼────────────────────────────────────────────────┼────────────────────────────────────┤
# │ MONGODB_URI     │ MongoDB connection string                       │ mongodb://localhost:27017/tabpilot │
# │ PORT            │ API server port                                 │ 3000                               │
# │ FRONTEND_URL    │ Web origin for CORS                             │ http://localhost:5173              │
# │ NODE_ENV        │ development | production                        │ development                        │
# └─────────────────┴────────────────────────────────────────────────┴────────────────────────────────────┘
#
# apps/web/.env
# ┌──────────────────┬────────────────────────────────────────────────┬───────────────────────┐
# │ Variable         │ Description                                    │ Default               │
# ├──────────────────┼────────────────────────────────────────────────┼───────────────────────┤
# │ VITE_API_URL     │ API base URL (no trailing slash)                │ http://localhost:3000 │
# └──────────────────┴────────────────────────────────────────────────┴───────────────────────┘
